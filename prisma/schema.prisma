generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PEGAWAI
}

model User {
  id               String                      @id @default(cuid())
  username         String                      @unique
  name             String // Nama lengkap, untuk identifikasi kasir
  password         String
  role             Role                        @default(PEGAWAI)
  isActive         Boolean                     @default(true)
  telegramChatId   String?                     @unique
  telegramUsername String?
  telegramLinkedAt DateTime?
  telegramTokens   TelegramLinkToken[]
  telegramStates   TelegramConversationState[]
  stockIns         StockIn[]
  stockOuts        StockOut[]
  sales            Sale[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
}

model TelegramLinkToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model TelegramConversationState {
  id        String   @id @default(cuid())
  chatId    String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String                 @id @default(cuid())
  name           String
  description    String?
  isArchived     Boolean                @default(false)
  archivedAt     DateTime?
  categoryId     String
  category       Category               @relation(fields: [categoryId], references: [id])
  variationTypes ProductVariationType[]
  variants       ProductVariant[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([categoryId])
}

model VariationType {
  id                    String                 @id @default(cuid())
  name                  String                 @unique // Contoh: Warna, Ukuran
  values                VariationValue[]
  productVariationTypes ProductVariationType[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model VariationValue {
  id                   String                @id @default(cuid())
  value                String // Contoh: Merah, Besar, 0.5mm
  variationTypeId      String
  variationType        VariationType         @relation(fields: [variationTypeId], references: [id])
  productVariantValues ProductVariantValue[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([variationTypeId, value]) // Tidak boleh duplikat nilai per tipe
  @@index([variationTypeId])
}

model ProductVariationType {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationTypeId String
  variationType   VariationType @relation(fields: [variationTypeId], references: [id])
  sortOrder       Int // Urutan level: 1=Ukuran, 2=Warna, 3=Ketebalan

  @@unique([productId, variationTypeId])
  @@index([productId])
}

model ProductVariant {
  id        String                @id @default(cuid())
  productId String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String                @unique // Dibuat otomatis, contoh: PLT-BSR-MRH-05
  price     Decimal               @db.Decimal(12, 2)
  stock     Int                   @default(0) // Stok aktual
  minStock  Int                   @default(0) // Ambang batas notifikasi
  isActive  Boolean               @default(true)
  values    ProductVariantValue[]
  stockIns  StockIn[]
  stockOuts StockOut[]
  saleItems SaleItem[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([productId])
}

model ProductVariantValue {
  id               String         @id @default(cuid())
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variationValueId String
  variationValue   VariationValue @relation(fields: [variationValueId], references: [id])

  @@unique([variantId, variationValueId])
  @@index([variantId])
}

model StockIn {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  note      String?
  // Pengelompokan: semua SKU pada satu kali pencatatan barang masuk berbagi batchId
  batchId   String?        @db.VarChar(36)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@index([variantId])
  @@index([createdAt])
  @@index([batchId])
}

model StockOut {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  quantity   Int
  note       String?
  // Pengelompokan barang keluar manual (non-penjualan); penjualan dikelompokkan lewat saleItem
  batchId    String?        @db.VarChar(36)
  userId     String
  user       User           @relation(fields: [userId], references: [id]) // Kasir pencatat transaksi
  saleItemId String?        @unique
  saleItem   SaleItem?      @relation(fields: [saleItemId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([variantId])
  @@index([createdAt])
  @@index([saleItemId])
  @@index([batchId])
}

model Sale {
  id            String     @id @default(cuid())
  receiptNumber String     @unique
  totalAmount   Decimal    @db.Decimal(12, 2)
  paidAmount    Decimal    @db.Decimal(12, 2)
  changeAmount  Decimal    @db.Decimal(12, 2)
  cashierId     String
  cashier       User       @relation(fields: [cashierId], references: [id])
  items         SaleItem[]
  createdAt     DateTime   @default(now())

  @@index([createdAt])
  @@index([cashierId])
}

model SaleItem {
  id        String         @id @default(cuid())
  saleId    String
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 2)
  subtotal  Decimal        @db.Decimal(12, 2)
  stockOut  StockOut?
  createdAt DateTime       @default(now())

  @@index([saleId])
  @@index([variantId])
  @@index([createdAt])
}
